{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/refs/heads/main/marketplace/marketplace.schema.json",
  "name": "ios-claude-plugins",
  "version": "1.0.0",
  "owner": {
    "name": "Naude Cruywagen",
    "email": "naude@hey.com"
  },
  "metadata": {
    "description": "A curated collection of Claude Code plugins for iOS/Swift development covering Clean Architecture, design patterns, and Test-Driven Development."
  },
  "plugins": [
    {
      "name": "clean-architecture-ios",
      "description": "Expert guidance on Clean Architecture and SOLID principles for iOS/Swift development.",
      "repository": "https://github.com/naudecruywagen/clean-architecture-ios",
      "version": "1.0.0",
      "author": {
        "name": "Naude Cruywagen"
      },
      "license": "MIT",
      "category": "development",
      "keywords": [
        "clean-architecture",
        "solid",
        "ios",
        "swift",
        "dependency-injection",
        "composition-root",
        "separation-of-concerns"
      ],
      "source": "./plugins/clean-architecture-ios",
      "skills": [
        "./plugins/clean-architecture-ios/.claude/skills/clean-architecture-ios"
      ]
    },
    {
      "name": "ios-design-patterns",
      "description": "Expert guidance on design patterns for iOS/Swift development.",
      "repository": "https://github.com/naudecruywagen/ios-design-patterns",
      "version": "1.0.0",
      "author": {
        "name": "Naude Cruywagen"
      },
      "license": "MIT",
      "category": "development",
      "keywords": [
        "design-patterns",
        "ios",
        "swift",
        "adapter",
        "composite",
        "strategy",
        "factory",
        "presenter",
        "proxy",
        "data-mapper"
      ],
      "source": "./plugins/ios-design-patterns",
      "skills": [
        "./plugins/ios-design-patterns/.claude/skills/ios-design-patterns"
      ]
    },
    {
      "name": "tdd",
      "description": "Expert guidance on Test-Driven Development with comprehensive iOS/Swift testing patterns.",
      "repository": "https://github.com/naudecruywagen/tdd-skill",
      "version": "1.0.0",
      "author": {
        "name": "Naude Cruywagen"
      },
      "license": "MIT",
      "category": "development",
      "keywords": [
        "swift",
        "ios",
        "tdd",
        "testing",
        "xctest",
        "swift-testing",
        "test-driven-development"
      ],
      "source": "./plugins/tdd",
      "skills": [
        "./plugins/tdd/.claude/skills/tdd"
      ]
    }
  ]
}
